APP_NAME=Real-Time Trading System API
APP_ENV=development
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
MARKET_DATA_DIR=./data/market
SIGNAL_DATA_DIR=./data/signals
RECOMMENDATION_DATA_DIR=./data/recommendations
DEFAULT_MARKET_PERIOD=5d
DEFAULT_MARKET_INTERVAL=1h
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/trading_system
REDIS_URL=redis://redis:6379/0
STORAGE_MODE=hybrid
