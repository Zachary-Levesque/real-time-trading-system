TICKER_UNIVERSE=sp500_top100
FEATURED_TICKER_COUNT=12
APP_NAME=Real-Time Trading System API
APP_ENV=development
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
MARKET_DATA_DIR=./data/market
SIGNAL_DATA_DIR=./data/signals
RECOMMENDATION_DATA_DIR=./data/recommendations
DEFAULT_MARKET_PERIOD=5d
DEFAULT_MARKET_INTERVAL=1h
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/trading_system
REDIS_URL=redis://redis:6379/0
STORAGE_MODE=hybrid
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
ENABLE_BACKGROUND_WORKER=true
BACKGROUND_WORKER_INTERVAL_SECONDS=300
BACKGROUND_WORKER_UNIVERSE=manual
BACKGROUND_WORKER_TICKERS=AAPL,MSFT,NVDA,SPY
BACKGROUND_WORKER_RUN_IMMEDIATELY=true
